@{
    ViewData["Title"] = ViewBag.PageTitle;

}
<h1>@ViewBag.PageTitle</h1>

<style>
    .items-container {
        max-width: 600px;
        margin: 80px auto;
        padding: 24px;
        background-color: #f8fafc;
        border-radius: 10px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

        .items-container h1 {
            text-align: center;
            margin-bottom: 20px;
            color: #1f2937;
        }

        .items-container ul {
            list-style: none;
            padding: 0;
        }

        .items-container li {
            background: #ffffff;
            margin-bottom: 12px;
            padding: 12px 16px;
            border-radius: 6px;
            border-left: 4px solid #3b82f6;
            color: #374151;
        }
</style>

<div class="items-container">
    <h1>Our Top Items</h1>

    <ul>
        <li>High-quality craftsmanship</li>
        <li>Fast and reliable delivery</li>
        <li>Excellent customer support</li>
    </ul>
</div>
