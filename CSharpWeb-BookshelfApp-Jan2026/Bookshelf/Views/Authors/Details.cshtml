@model Author
@{
    ViewData["Title"] = "Author Details";
}

<h1 class="mb-1">@Model.Name</h1>
<p class="text-muted">Country:@(Model.Country ?? "-")</p>

<hr />

<h4 class="mb-3">Books by this author</h4>

@if (!Model.Books.Any())
{
    <p class="text-muted">No books available.</p>
}
else
{
    @foreach (var book in Model.Books)
    {

        <partial name="_BookCard" model="book" />
    }
}
